  "keyFeatures": [
    "Validates container image age, size, and layer count",
    "Checks registry trust policies and security configurations",
    "Detects exposed ports, root users, and missing healthchecks",
    "Scans for secrets in environment variables and filesystem",
    "Validates OCI labels and platform compatibility",
    "Supports multiple image sources: Docker daemon, registries, OCI archives",
    "Private registry authentication with multiple credential sources",
    "JSON and text output formats with configurable color modes",
    "Comprehensive policy configuration via JSON/YAML files",
    "Available as CLI binary, Docker image, and GitHub Action"
  ],
  "publicApiSurface": [
    "age - Validate image creation date",
    "size - Validate image size and layer count",
    "registry - Validate registry trust policy",
    "ports - Validate exposed ports",
    "root-user - Validate non-root execution",
    "healthcheck - Validate healthcheck presence",
    "secrets - Scan for sensitive data",
    "entrypoint - Validate startup command",
    "labels - Validate OCI annotations",
    "platform - Validate OS/architecture",
    "all - Run all validation checks",
    "version - Display version information"
  ]
}
